@{
    ViewData["Title"] = "Dashboard Thống kê";
}

<h1 class="mb-4">Admin Dashboard</h1>

<div class="row">
    <div class="col-md-4 mb-4">
        <div class="card bg-primary text-white shadow">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-uppercase mb-1">Tổng số học phần</h6>
                        <h2 class="mb-0">@ViewData["TotalCourses"]</h2>
                    </div>
                    <div>
                        <i class="bi bi-book fs-1"></i>
                    </div>
                </div>
            </div>
            <div class="card-footer d-flex align-items-center justify-content-between">
                <a class="small text-white stretched-link" asp-controller="AdminCourses" asp-action="Index">Xem chi tiết</a>
                <div class="small text-white"><i class="bi bi-chevron-right"></i></div>
            </div>
        </div>
    </div>
    
    <div class="col-md-4 mb-4">
        <div class="card bg-success text-white shadow">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-uppercase mb-1">Tổng số sinh viên</h6>
                        <h2 class="mb-0">@ViewData["TotalStudents"]</h2>
                    </div>
                    <div>
                        <i class="bi bi-people fs-1"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-md-4 mb-4">
        <div class="card bg-warning text-white shadow">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-uppercase mb-1">Tổng lượt đăng ký</h6>
                        <h2 class="mb-0">@ViewData["TotalEnrollments"]</h2>
                    </div>
                    <div>
                        <i class="bi bi-card-checklist fs-1"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
